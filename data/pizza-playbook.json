    {
      "id": "cold-ferment",
      "title": "Cold Ferment (Direct)",
      "meta": "September 2025 · 9 balls × 320g · 67% hydration",
      "ingredients": [
        { "name": "Type 00 Flour", "amount": "1 700g" },
        { "name": "Water", "amount": "1 140g (67%)" },
        { "name": "Instant dry yeast", "amount": "1.86g" },
        { "name": "Salt", "amount": "50g" }
      ],
      "steps": [
        "Mix cold water + yeast, then incorporate into flour at medium-low speed",
        "Add salt last. Knead 10 min total.",
        "Cold ferment in fridge 24h",
        "Remove 2h before. Form balls, let double in size."
      ]
    },
    {
      "id": "halo",
      "title": "Halo Pro Recipe",
      "meta": "5 balls × 12\" · 60% hydration",
      "ingredients": [
        { "name": "Type 00 Flour", "amount": "607g" },
        { "name": "Water", "amount": "364g (60%)" },
        { "name": "Salt", "amount": "18g" },
        { "name": "Instant dried yeast", "amount": "7g" }
      ],
      "tip": "Also works with 9.2g active dry yeast or 20g fresh yeast.",
      "steps": [
        "Mix water + salt, then add yeast",
        "Incorporate into flour. Mix then rest 20 min.",
        "Knead 10 min (no extra flour needed)",
        "Coat bowl with olive oil. Proof 8–24h at room temp or in fridge overnight"
      ]
    }
